# 数据库配置
DATABASE_URL=postgresql://postgres:postgres123@localhost:5432/wind_whisper_rag
DATABASE_ECHO=false
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20

# 服务器配置
HOST=0.0.0.0
PORT=8003
DEBUG=false
RELOAD=false
WORKERS=1

# AI模型配置
LLM_MODEL_NAME=Qwen/Qwen3-4B-Instruct-2507
LLM_LOCAL_PATH=/app/ai_models/Qwen3-4B-Instruct-2507
LLM_MAX_LENGTH=2048
LLM_TEMPERATURE=0.0
LLM_TOP_P=1.0

EMBEDDING_MODEL_NAME=BAAI/bge-m3
EMBEDDING_LOCAL_PATH=/app/ai_models/bge-m3
EMBEDDING_BATCH_SIZE=32

TRANSFORMERS_OFFLINE=true
HF_HUB_OFFLINE=true

# RAG配置
RAG_CHUNK_SIZE=500
RAG_CHUNK_OVERLAP=50
RAG_TOP_K=5
RAG_SIMILARITY_THRESHOLD=0.7
RAG_MAX_CONTEXT_LENGTH=4000

# 安全配置
SECRET_KEY=wind-whisper-secret-key-2024
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# 文件存储配置
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=10485760
ALLOWED_EXTENSIONS=.pdf,.txt,.docx,.md

# 日志配置
LOG_LEVEL=INFO
LOG_FORMAT=%(asctime)s - %(name)s - %(levelname)s - %(message)s

# 测试配置
TEST_BASE_URL=http://localhost:8003
TEST_TIMEOUT=30
TEST_DATABASE_URL=postgresql://postgres:postgres123@localhost:5432/wind_whisper_rag_test

# 应用信息
APP_NAME=Wind Whisper RAG System
APP_VERSION=1.0.0
APP_DESCRIPTION=基于RAG的智能问答系统