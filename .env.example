# 数据库配置
DATABASE_URL=postgresql://postgres:postgres123@localhost:5432/wind_whisper_rag

# JWT配置
JWT_SECRET_KEY=your-secret-key-change-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Hugging Face模型配置
HF_MODEL_NAME=Qwen/Qwen2-1.5B-Instruct
# 可选的其他模型：microsoft/DialoGPT-medium, google/flan-t5-base

# 应用配置
APP_HOST=0.0.0.0
APP_PORT=8000
DEBUG=False

# 文件存储
ATTACHMENT_PATH=/app/data/attachments
MAX_FILE_SIZE=50MB